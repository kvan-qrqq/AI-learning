```gitignore
# Dependencies
node_modules/

# Environment variables
.env
.env.local
.env.*

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.ENV
.python-version

# Logs
*.log

# Coverage
.coverage
coverage/
htmlcov/

# Temporary files
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
*.egg-info/

# IDE
.vscode/
.idea/

# Package manager
package-lock.json
yarn.lock
npm-debug.log*
yarn-error.log*

# Testing
.pytest_cache/
.mypy_cache/
```